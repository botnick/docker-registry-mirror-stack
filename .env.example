# Ports
REGISTRY_PORT=5000
CONTROL_BIND_ADDRESS=127.0.0.1
CONTROL_PORT=8080

# Public URL and cookies
PUBLIC_BASE_URL=
COOKIE_SECURE=true
ALLOW_INSECURE_CONTROL=false
TRUST_PROXY_HEADERS=true

# If you intentionally expose the control UI over direct HTTP such as http://IP:8080,
# switch to:
# PUBLIC_BASE_URL=http://YOUR_SERVER_IP:8080
# COOKIE_SECURE=false
# ALLOW_INSECURE_CONTROL=true
# TRUST_PROXY_HEADERS=false

# Registry notifications
NOTIFICATIONS_USERNAME=registry-notify
NOTIFICATIONS_PASSWORD=CHANGE_ME

# Sessions
SESSION_SECRET=CHANGE_ME
SESSION_TTL_HOURS=24
SESSION_REFRESH_MINUTES=15

# First-run bootstrap account
CONTROL_BOOTSTRAP_USERNAME=admin
CONTROL_BOOTSTRAP_PASSWORD=
CONTROL_BOOTSTRAP_FORCE_PASSWORD_CHANGE=false

# Cleanup policy
DRY_RUN=false
JANITOR_INTERVAL_SECONDS=3600
MAX_DELETE_BATCH=20
UNUSED_DAYS=30
MIN_CACHE_AGE_DAYS=3
LOW_WATERMARK_PCT=20
TARGET_FREE_PCT=35
EMERGENCY_FREE_PCT=10
GC_HOUR_UTC=19

# Protection rules
PROTECTED_REPOS_REGEX=^(library/)?(alpine|ubuntu|busybox|debian)$
PROTECTED_TAGS_REGEX=^(latest|stable|lts)$

# Health and fallback
UPSTREAM_HEALTH_URL=https://registry-1.docker.io/v2/
HEALTH_CHECK_INTERVAL_SECONDS=60
UPSTREAM_TIMEOUT_SECONDS=6

# Retention
LOG_RETENTION_DAYS=30
EVENT_RETENTION_DAYS=30
JOB_RETENTION_DAYS=90

# Login protection
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# GC worker
GC_WORKER_POLL_SECONDS=15
